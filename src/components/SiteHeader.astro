---
const links = [
  { label: "Blog", href: "/blog/" },
  { label: "Docs", href: "/docs/" },
];

const currentPath = Astro.url.pathname;
---

<header class="masthead" aria-label="Site header">
  <a class="flame-link" href="/" aria-label="Home">
    <svg class="flame" viewBox="0 0 84 96" role="img" aria-label="Flame">
      <path
        d="M49.9 3.6c3.2 17.9-7.9 28.1-15.9 38-6.8 8.4-9.5 16.1-4.3 25.6-9.2-3.4-15.1-10.2-16.5-19.3C3 58.8 1.6 72.6 9.8 83.6c7.6 10.1 21 13.4 32.8 10.6 15-3.6 27-15.7 28.5-31.2 1.4-14-5.6-25.4-16.2-31.9 2.3 8-.1 15.8-6.4 21.7 1.3-13.2-6.4-23.1-17.6-32.7 3 .1 12.2 3.8 19 11.4 4.9-12.7 1.9-21.8 0-27.9Z"
        fill="currentColor"
      />
    </svg>
  </a>

  <div class="masthead-right">
    <nav class="site-nav" aria-label="Primary navigation">
      {
        links.map((link) => (
          <a class:list={{ active: currentPath.startsWith(link.href) }} href={link.href}>
            {link.label}
          </a>
        ))
      }
    </nav>

    <a class="wordmark" href="/" aria-label="neonity dot cc home">
      <span>NEONITY</span><b>.cc</b>
    </a>
  </div>
</header>
