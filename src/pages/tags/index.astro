---
import Layout from '../../layouts/IndexLayout.astro';
import { getAllTags, getPublishedPosts, getTagHref } from '../../lib/posts';

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<Layout title="标签" description="浏览 neonity.cc 的所有文章标签">
	<main class="page">
		<p class="eyebrow">TOPICS</p>
		<h1>标签</h1>
		<p class="page_intro">从感兴趣的主题开始阅读。</p>
		<div class="tag_cloud">
			{tags.map((tag) => (
				<a href={getTagHref(tag)}><span>#{tag}</span><strong>{posts.filter((post) => post.data.tags.includes(tag)).length}</strong></a>
			))}
		</div>
	</main>
</Layout>
